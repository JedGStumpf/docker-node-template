DEPLOYMENT=dev
DATABASE_URL=file:./data/dev.db
# DATABASE_URL=postgresql://app:devpassword@localhost:5433/app
APP_DOMAIN=localhost
APP_NAME=League Chat
APP_SLUG=league-chat

# OAuth callback URLs (non-secret, environment-specific)
GITHUB_CALLBACK_URL=http://localhost:5173/api/auth/github/callback
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
PIKE13_CALLBACK_URL=http://localhost:5173/api/auth/pike13/callback
PIKE13_API_BASE=https://jtl.pike13.com/api/v2/desk

# DigitalOcean Spaces endpoint and bucket (not secret)
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_BUCKET=league-student-storage
DO_SPACES_REGION=sfo3

# Sprint 1: Content service — class catalog
CONTENT_JSON_URL=https://jointheleague.org/content.json
CONTENT_CACHE_TTL_MS=300000

# Sprint 1: Availability look-ahead window (days)
AVAILABILITY_LOOKAHEAD_DAYS=90

# Sprint 1: Request verification expiry (ms) — default 1 hour
VERIFICATION_EXPIRY_MS=3600000

# Sprint 1: Instructor consent config
INSTRUCTOR_REMINDER_INTERVAL_HOURS=8
INSTRUCTOR_TIMEOUT_HOURS=24

# Sprint 1: Background job intervals (ms)
REQUEST_EXPIRY_INTERVAL_MS=300000
REMINDER_INTERVAL_MS=900000

# Sprint 1: Admin email for notifications
ADMIN_EMAIL=admin@jointheleague.org
APP_BASE_URL=http://localhost:5173
