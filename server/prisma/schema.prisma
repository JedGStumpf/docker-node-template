generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Runtime configuration store for admin-managed credentials.
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  displayName String?
  role        UserRole  @default(USER)
  avatarUrl   String?
  provider    String?
  providerId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  providers   UserProvider[]

  @@unique([provider, providerId])
}

model UserProvider {
  id         Int      @id @default(autoincrement())
  userId     Int
  provider   String
  providerId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

model Channel {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  channelId Int
  authorId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
}

model RoleAssignmentPattern {
  id        Int      @id @default(autoincrement())
  matchType String   // 'exact' or 'regex'
  pattern   String   // email address or regex pattern
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchType, pattern])
}

model ScheduledJob {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  frequency String    // 'daily', 'weekly', 'hourly'
  enabled   Boolean   @default(true)
  lastRun   DateTime?
  nextRun   DateTime?
  lastError String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Express session store (PrismaSessionStore).
model Session {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamptz(6)

  @@index([expire])
  @@map("session")
}

// ── Sprint 1: Request Intake & Instructor Matching ──────────────────────────

enum RequestStatus {
  unverified
  new
  discussing
  dates_proposed
  confirmed
  completed
  cancelled
}

enum AssignmentStatus {
  pending
  accepted
  declined
  timed_out
}

model InstructorProfile {
  id               Int       @id @default(autoincrement())
  pike13UserId     String    @unique
  displayName      String
  email            String
  topics           String[]
  homeZip          String
  maxTravelMinutes Int       @default(60)
  serviceZips      String[]  @default([])
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignments      InstructorAssignment[]
}

model EventRequest {
  id                      String         @id @default(uuid())
  classSlug               String
  requesterName           String
  requesterEmail          String
  groupType               String
  expectedHeadcount       Int
  zipCode                 String
  locationFreeText        String?
  preferredDates          String[]
  externalRegistrationUrl String?
  siteControl             String?
  siteReadiness           String?
  marketingCapability     String?
  verificationToken       String         @unique
  verificationExpiresAt   DateTime
  status                  RequestStatus  @default(unverified)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  assignments             InstructorAssignment[]
}

model InstructorAssignment {
  id                String           @id @default(uuid())
  requestId         String
  instructorId      Int
  status            AssignmentStatus @default(pending)
  notificationToken String           @unique
  notifiedAt        DateTime?
  respondedAt       DateTime?
  reminderCount     Int              @default(0)
  lastReminderAt    DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  request           EventRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  instructor        InstructorProfile @relation(fields: [instructorId], references: [id])
}
